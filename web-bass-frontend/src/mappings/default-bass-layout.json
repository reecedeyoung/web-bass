{
  "$schema": "./key-mapping.schema.json",
  "name": "Default Bass Layout",
  "description": "One keyboard row per string. Bottom row = E, home row = A, top row = D, number row = G. First key in each row is the open string; each subsequent key adds one fret (semitone).",
  "version": 1,
  "mappings": {
    "z": { "note": 28, "channel": 1, "label": "E1"  },
    "x": { "note": 29, "channel": 1, "label": "F1"  },
    "c": { "note": 30, "channel": 1, "label": "F#1" },
    "v": { "note": 31, "channel": 1, "label": "G1"  },
    "b": { "note": 32, "channel": 1, "label": "G#1" },
    "n": { "note": 33, "channel": 1, "label": "A1"  },
    "m": { "note": 34, "channel": 1, "label": "A#1" },
    ",": { "note": 35, "channel": 1, "label": "B1"  },
    ".": { "note": 36, "channel": 1, "label": "C2"  },
    "/": { "note": 37, "channel": 1, "label": "C#2" },

    "a": { "note": 33, "channel": 2, "label": "A1"  },
    "s": { "note": 34, "channel": 2, "label": "A#1" },
    "d": { "note": 35, "channel": 2, "label": "B1"  },
    "f": { "note": 36, "channel": 2, "label": "C2"  },
    "g": { "note": 37, "channel": 2, "label": "C#2" },
    "h": { "note": 38, "channel": 2, "label": "D2"  },
    "j": { "note": 39, "channel": 2, "label": "D#2" },
    "k": { "note": 40, "channel": 2, "label": "E2"  },
    "l": { "note": 41, "channel": 2, "label": "F2"  },
    ";": { "note": 42, "channel": 2, "label": "F#2" },

    "q": { "note": 38, "channel": 3, "label": "D2"  },
    "w": { "note": 39, "channel": 3, "label": "D#2" },
    "e": { "note": 40, "channel": 3, "label": "E2"  },
    "r": { "note": 41, "channel": 3, "label": "F2"  },
    "t": { "note": 42, "channel": 3, "label": "F#2" },
    "y": { "note": 43, "channel": 3, "label": "G2"  },
    "u": { "note": 44, "channel": 3, "label": "G#2" },
    "i": { "note": 45, "channel": 3, "label": "A2"  },
    "o": { "note": 46, "channel": 3, "label": "A#2" },
    "p": { "note": 47, "channel": 3, "label": "B2"  },

    "1": { "note": 43, "channel": 4, "label": "G2"  },
    "2": { "note": 44, "channel": 4, "label": "G#2" },
    "3": { "note": 45, "channel": 4, "label": "A2"  },
    "4": { "note": 46, "channel": 4, "label": "A#2" },
    "5": { "note": 47, "channel": 4, "label": "B2"  },
    "6": { "note": 48, "channel": 4, "label": "C3"  },
    "7": { "note": 49, "channel": 4, "label": "C#3" },
    "8": { "note": 50, "channel": 4, "label": "D3"  },
    "9": { "note": 51, "channel": 4, "label": "D#3" },
    "0": { "note": 52, "channel": 4, "label": "E3"  }
  }
}
